[
  {
    "name": "theme_info",
    "theme_name": "Off Duty",
    "theme_version": "1.0.0",
    "theme_author": "Off Duty",
    "theme_documentation_url": "https://help.shopify.com",
    "theme_support_url": "https://help.shopify.com"
  },
  {
    "name": "Favicon",
    "settings": [
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon",
        "info": "Will display in the browser tab. Recommended size: 32 x 32 px."
      }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "checkbox",
        "id": "use_okay_font",
        "label": "Use Okay font (custom)",
        "info": "Enable to use the Okay font. Add okay.woff2 to the assets folder. Okay is a commercial font from Okay Type (okaytype.com).",
        "default": false
      },
      {
        "type": "font_picker",
        "id": "font_body",
        "label": "Body font",
        "default": "work_sans_n4"
      },
      {
        "type": "font_picker",
        "id": "font_heading",
        "label": "Heading font",
        "default": "work_sans_n4"
      },
      {
        "type": "range",
        "id": "font_size_base",
        "min": 12,
        "max": 24,
        "step": 1,
        "unit": "px",
        "label": "Base font size",
        "default": 16
      },
      {
        "type": "range",
        "id": "font_size_heading",
        "min": 18,
        "max": 48,
        "step": 1,
        "unit": "px",
        "label": "Heading font size",
        "default": 32
      },
      {
        "type": "range",
        "id": "font_weight_normal",
        "min": 300,
        "max": 700,
        "step": 100,
        "label": "Normal font weight",
        "default": 400
      },
      {
        "type": "range",
        "id": "font_weight_medium",
        "min": 300,
        "max": 700,
        "step": 100,
        "label": "Medium font weight",
        "default": 500
      },
      {
        "type": "range",
        "id": "font_weight_bold",
        "min": 300,
        "max": 700,
        "step": 100,
        "label": "Bold font weight",
        "default": 700
      }
    ]
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "color",
        "id": "color_background",
        "label": "Background",
        "default": "#ffffff"
      },
      {
        "type": "color",
        "id": "color_foreground",
        "label": "Foreground / Text",
        "default": "#1a1a1a"
      },
      {
        "type": "color",
        "id": "color_accent",
        "label": "Accent",
        "default": "#000000"
      },
      {
        "type": "range",
        "id": "header_scrolled_opacity",
        "min": 0,
        "max": 100,
        "step": 5,
        "unit": "%",
        "label": "Header scrolled opacity",
        "default": 5
      }
    ]
  },
  {
    "name": "Buttons",
    "settings": [
      {
        "type": "range",
        "id": "button_border_radius",
        "min": 0,
        "max": 24,
        "step": 1,
        "unit": "px",
        "label": "Border radius",
        "default": 4
      },
      {
        "type": "range",
        "id": "button_padding_y",
        "min": 8,
        "max": 32,
        "step": 2,
        "unit": "px",
        "label": "Vertical padding",
        "default": 14
      },
      {
        "type": "range",
        "id": "button_padding_x",
        "min": 16,
        "max": 64,
        "step": 2,
        "unit": "px",
        "label": "Horizontal padding",
        "default": 28
      }
    ]
  },
  {
    "name": "Spacing",
    "settings": [
      {
        "type": "range",
        "id": "section_padding_y",
        "min": 24,
        "max": 120,
        "step": 4,
        "unit": "px",
        "label": "Section vertical padding",
        "default": 60
      },
      {
        "type": "range",
        "id": "section_padding_x",
        "min": 16,
        "max": 80,
        "step": 4,
        "unit": "px",
        "label": "Section horizontal padding",
        "default": 24
      },
      {
        "type": "range",
        "id": "page_width",
        "min": 960,
        "max": 1600,
        "step": 20,
        "unit": "px",
        "label": "Max width",
        "default": 1200
      }
    ]
  }
]
