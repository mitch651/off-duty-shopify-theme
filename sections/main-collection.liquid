{%- comment -%} Sidebar: Discover (Shop All) + Shop By (collapsible categories). Drawer on mobile. {%- endcomment -%}
<section class="collection-page">
  <div class="page-width collection-page__inner">
    <div class="collection-page__sidebar-backdrop" id="collection-sidebar-backdrop" data-collection-drawer-close aria-hidden="true"></div>
    <button type="button" class="collection-page__sidebar-trigger" aria-expanded="false" aria-controls="collection-sidebar" data-collection-drawer-trigger>
      <span class="collection-page__sidebar-trigger-text">{{ section.settings.sidebar_heading | default: 'Collections' }}</span>
      <svg width="10" height="10" fill="none" stroke="currentColor" stroke-width="1.2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" d="M9 5l7 7-7 7"/></svg>
    </button>
    <aside class="collection-page__sidebar" id="collection-sidebar" aria-hidden="false" data-collection-sidebar>
      <div class="collection-page__sidebar-header">
        <button type="button" class="collection-page__sidebar-close" aria-label="Close" data-collection-drawer-close>
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.3" viewBox="0 0 24 24"><path stroke-linecap="round" d="M6 6l12 12M6 18L18 6"/></svg>
        </button>
        <span class="collection-page__sidebar-title">{{ section.settings.sidebar_heading | default: 'Collections' }}</span>
      </div>
      <div class="collection-page__sidebar-content" id="collection-sidebar-content">
        <div class="collection-page__sidebar-group">
          <p class="collection-page__sidebar-label">{{ section.settings.discover_heading | default: 'Discover' }}</p>
          <ul class="collection-page__filters">
            <li>
              <a href="{{ routes.all_products_collection_url }}" class="collection-page__filter{% if collection.handle == 'all' %} is-active{% endif %}" data-collection-drawer-close>{{ 'collections.all' | t | default: 'Shop All' }}</a>
            </li>
          </ul>
        </div>
        {% assign has_categories = false %}
        {% if section.blocks.size > 0 %}{% assign has_categories = true %}{% endif %}
        {% if section.settings.sidebar_menu != blank and has_categories == false %}{% assign has_categories = true %}{% endif %}
        {% if has_categories %}
        <div class="collection-page__sidebar-group collection-page__sidebar-group--collapsible" data-collapsible-group>
          <button type="button" class="collection-page__sidebar-group-toggle" aria-expanded="true" aria-controls="collection-shop-by" data-collapsible-toggle>
            <span class="collection-page__sidebar-label">{{ section.settings.shop_by_heading | default: 'Shop By' }}</span>
            <span class="collection-page__sidebar-group-icon" aria-hidden="true"></span>
          </button>
          <ul class="collection-page__filters" id="collection-shop-by">
            {% if section.blocks.size > 0 %}
              {% for block in section.blocks %}
                {% if block.type == 'category' and block.settings.collection != blank %}
                  {% assign cat_collection = block.settings.collection %}
                  <li {{ block.shopify_attributes }}>
                    <a href="{{ cat_collection.url }}" class="collection-page__filter{% if collection.handle == cat_collection.handle %} is-active{% endif %}" data-collection-drawer-close>{{ block.settings.heading | default: cat_collection.title }}</a>
                  </li>
                {% endif %}
              {% endfor %}
            {% elsif section.settings.sidebar_menu != blank %}
              {% for link in section.settings.sidebar_menu.links %}
                {% if link.type == 'collection_link' and link.object %}
                  <li>
                    <a href="{{ link.url }}" class="collection-page__filter{% if link.active or collection.handle == link.object.handle %} is-active{% endif %}" data-collection-drawer-close>{{ link.title }}</a>
                  </li>
                {% else %}
                  <li>
                    <a href="{{ link.url }}" class="collection-page__filter{% if link.active %} is-active{% endif %}" data-collection-drawer-close>{{ link.title }}</a>
                  </li>
                {% endif %}
              {% endfor %}
            {% endif %}
          </ul>
        </div>
        {% endif %}
      </div>
    </aside>
    <div class="collection-page__main">
      <div class="collection-page__header">
        <h1 class="collection-page__title">{{ collection.title }}</h1>
        <p class="collection-page__count">{{ collection.products_count }} {{ 'collections.products' | t | default: 'products' }}</p>
      </div>
      <div class="collection-page__grid">
        {% for product in collection.products %}
          {% render 'product-card', product: product %}
        {% endfor %}
      </div>
      {% if collection.products_count == 0 %}
        <p class="collection-page__empty">{{ 'collections.empty' | t | default: 'No products in this collection yet.' }}</p>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Collection",
  "settings": [
    {
      "type": "text",
      "id": "sidebar_heading",
      "label": "Sidebar / trigger button label",
      "default": "Collections"
    },
    {
      "type": "text",
      "id": "discover_heading",
      "label": "Discover section heading",
      "default": "Discover"
    },
    {
      "type": "text",
      "id": "shop_by_heading",
      "label": "Shop By section heading",
      "default": "Shop By"
    },
    {
      "type": "link_list",
      "id": "sidebar_menu",
      "label": "Collections menu (fallback)",
      "info": "Used when no category blocks exist. Create a menu with links to collections. Shop All is always first."
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Category"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection",
      "blocks": [
        { "type": "category", "settings": { "heading": "T-Shirts" } },
        { "type": "category", "settings": { "heading": "Hoodies" } },
        { "type": "category", "settings": { "heading": "Sweatpants" } }
      ]
    }
  ]
}
{% endschema %}
