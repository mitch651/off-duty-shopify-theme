<div class="page-width" style="padding-top: 48px; padding-bottom: 64px;">
  {% if section.settings.show_heading %}
    <h1 class="page__title">{{ section.settings.heading | default: page.title }}</h1>
  {% endif %}
  <div class="page__content rte">
    {{ page.content }}
  </div>
</div>

<style>
.page__title {
  font-size: 12px;
  letter-spacing: 0.25em;
  font-weight: var(--font-weight-medium);
  margin: 0 0 24px;
}
.page__content {
  font-size: 12px;
  color: #555;
  line-height: 1.8;
  text-transform: none;
}
.page__content p { margin: 0 0 1em; }
</style>

{% schema %}
{
  "name": "Page",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_heading",
      "label": "Show heading",
      "default": true
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading (leave blank to use page title)"
    }
  ]
}
{% endschema %}
