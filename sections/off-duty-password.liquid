{%- comment -%} Password page: full-screen hero with image, heading, text, password form, and email signup. {%- endcomment -%}
<section class="password-page" style="{% if section.settings.image != blank %}background-image: url({{ section.settings.image | image_url: width: 1920 }});{% else %}background-color: #181818;{% endif %}">
  <div class="password-page__overlay" style="background-color: {{ section.settings.overlay_color }}; opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};"></div>
  <div class="password-page__content">
    {% if section.settings.heading != blank %}
      <h1 class="password-page__heading">{{ section.settings.heading }}</h1>
    {% else %}
      <h1 class="password-page__heading">{{ shop.name }}</h1>
    {% endif %}
    {% if section.settings.text != blank %}
      <p class="password-page__text">{{ section.settings.text }}</p>
    {% endif %}

    {% form 'storefront_password', class: 'password-page__form' %}
      <div class="password-page__input-wrap">
        <input
          type="password"
          name="password"
          placeholder="{{ 'general.password_page.login_form_password_placeholder' | t }}"
          class="password-page__input"
          autocomplete="current-password"
        >
        <button type="submit" class="password-page__submit">{{ section.settings.button_text | default: 'Enter' }}</button>
      </div>
      {% if form.errors %}
        <p class="password-page__error">{{ form.errors.messages['form'] }}</p>
      {% endif %}
    {% endform %}

    {% if section.settings.show_signup %}
      {% form 'customer', class: 'password-page__signup' %}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <p class="password-page__signup-label">{{ section.settings.signup_label | default: 'Get notified when we launch' }}</p>
        <div class="password-page__signup-row">
          <input type="email" name="contact[email]" placeholder="{{ 'general.newsletter_form.email_placeholder' | t }}" class="password-page__signup-input" required>
          <button type="submit" class="password-page__signup-btn">{{ section.settings.signup_button | default: 'Notify me' }}</button>
        </div>
      {% endform %}
    {% endif %}
  </div>
</section>

<style>
.password-page {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background-size: cover;
  background-position: center;
  position: relative;
}
.password-page__overlay {
  position: absolute;
  inset: 0;
}
.password-page__content {
  position: relative;
  z-index: 2;
  text-align: center;
  padding: 40px 24px;
  max-width: 420px;
}
.password-page__heading {
  font-size: 24px;
  letter-spacing: 0.2em;
  color: #fff;
  margin: 0 0 16px;
}
.password-page__text {
  font-size: 12px;
  letter-spacing: 0.1em;
  color: rgba(255,255,255,0.9);
  margin: 0 0 32px;
  text-transform: none;
  line-height: 1.6;
}
.password-page__form { margin-bottom: 32px; }
.password-page__input-wrap {
  display: flex;
  border: 1px solid rgba(255,255,255,0.5);
}
.password-page__input {
  flex: 1;
  padding: 14px 16px;
  background: transparent;
  border: none;
  color: #fff;
  font-size: 12px;
  font-family: inherit;
  letter-spacing: 0.1em;
}
.password-page__input::placeholder { color: rgba(255,255,255,0.6); }
.password-page__input:focus { outline: none; }
.password-page__submit {
  padding: 14px 24px;
  background: #fff;
  color: #181818;
  border: none;
  font-size: 11px;
  letter-spacing: 0.2em;
  font-weight: 500;
  cursor: pointer;
  font-family: inherit;
}
.password-page__error {
  font-size: 11px;
  color: #ff6b6b;
  margin: 8px 0 0;
}
.password-page__signup { text-align: left; }
.password-page__signup-label {
  font-size: 10px;
  letter-spacing: 0.2em;
  color: rgba(255,255,255,0.8);
  margin: 0 0 12px;
}
.password-page__signup-row {
  display: flex;
  border: 1px solid rgba(255,255,255,0.5);
}
.password-page__signup-input {
  flex: 1;
  padding: 12px 14px;
  background: transparent;
  border: none;
  color: #fff;
  font-size: 11px;
  font-family: inherit;
}
.password-page__signup-input::placeholder { color: rgba(255,255,255,0.5); }
.password-page__signup-input:focus { outline: none; }
.password-page__signup-btn {
  padding: 12px 20px;
  background: transparent;
  color: #fff;
  border-left: 1px solid rgba(255,255,255,0.3);
  font-size: 10px;
  letter-spacing: 0.15em;
  cursor: pointer;
  font-family: inherit;
}
</style>

{% schema %}
{
  "name": "Password page",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "label": "Overlay opacity",
      "default": 50
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Opening soon"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Enter button text",
      "default": "Enter"
    },
    {
      "type": "checkbox",
      "id": "show_signup",
      "label": "Show email signup",
      "default": true
    },
    {
      "type": "text",
      "id": "signup_label",
      "label": "Signup label",
      "default": "Get notified when we launch"
    },
    {
      "type": "text",
      "id": "signup_button",
      "label": "Signup button text",
      "default": "Notify me"
    }
  ]
}
{% endschema %}
