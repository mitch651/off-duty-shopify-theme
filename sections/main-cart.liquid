<div class="page-width cart">
  <h1 class="cart__title">{{ 'cart.general.title' | t | default: 'Cart' }}</h1>
  {% if cart.item_count > 0 %}
    <form action="{{ routes.cart_url }}" method="post" class="cart__form">
      <div class="cart__items">
        {% for item in cart.items %}
          <div class="cart__item">
            <a href="{{ item.url }}" class="cart__item-image-wrap">
              {% if item.image %}
                <img src="{{ item.image | image_url: width: 360 }}" alt="{{ item.title | escape }}" class="cart__item-image" loading="lazy" width="180" height="240">
              {% else %}
                {{ 'product-1' | placeholder_svg_tag: 'cart__item-placeholder' }}
              {% endif %}
            </a>
            <div class="cart__item-details">
              <a href="{{ item.url }}" class="cart__item-title">{{ item.product.title }}</a>
              {% unless item.variant.title == 'Default Title' %}<p class="cart__item-variant">{{ item.variant.title }}</p>{% endunless %}
              <p class="cart__item-price">{{ item.final_line_price | money }}</p>
              <div class="cart__item-qty">
                <label for="updates-{{ item.key }}" class="visually-hidden">{{ 'cart.general.update' | t | default: 'Quantity' }} {{ item.product.title }}</label>
                <input type="number" id="updates-{{ item.key }}" name="updates[{{ item.key }}]" value="{{ item.quantity }}" min="0" class="cart__item-qty-input" aria-label="{{ 'cart.general.update' | t | default: 'Update' }} {{ item.product.title }}">
              </div>
            </div>
            <a href="{{ routes.cart_change_url }}?line={{ forloop.index }}&quantity=0" class="cart__item-remove" aria-label="{{ 'cart.general.remove' | t | default: 'Remove' }} {{ item.product.title }}">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M18 6L6 18M6 6l12 12"/></svg>
            </a>
          </div>
        {% endfor %}
      </div>
      <div class="cart__footer">
        <p class="cart__total">{{ 'cart.general.subtotal' | t | default: 'Subtotal' }}: {{ cart.total_price | money }}</p>
        <div class="cart__actions">
          <button type="submit" name="update" class="cart__update">{{ 'cart.general.update' | t | default: 'Update' }}</button>
          <a href="/checkout" class="cart__checkout">{{ 'cart.general.checkout' | t | default: 'Checkout' }}</a>
        </div>
      </div>
    </form>
  {% else %}
    <p class="cart__empty">{{ 'cart.general.empty' | t | default: 'Your cart is empty.' }}</p>
    <a href="{{ routes.collections_url }}" class="cart__continue">{{ 'cart.general.continue_shopping' | t | default: 'Continue shopping' }}</a>
  {% endif %}
</div>

{% schema %}
{
  "name": "Cart",
  "settings": []
}
{% endschema %}
