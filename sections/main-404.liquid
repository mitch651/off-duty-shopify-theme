<div class="page-width" style="padding: 80px 24px; text-align: center;">
  <h1 style="font-size: 48px; font-weight: 300; letter-spacing: 0.2em; margin: 0 0 16px;">404</h1>
  <p style="font-size: 12px; letter-spacing: 0.2em; color: #666; margin: 0 0 32px;">{{ 'general.404.title' | t | default: 'Page not found' }}</p>
  <a href="{{ routes.root_url }}" style="font-size: 11px; letter-spacing: 0.2em;">{{ 'general.404.link' | t | default: 'Back to home' }}</a>
</div>

{% schema %}
{
  "name": "404",
  "settings": []
}
{% endschema %}
