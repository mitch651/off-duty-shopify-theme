{%- comment -%} Lookbook: catalog-style 1:1 photos, no background. Optional inset (picture-in-picture). Alt: use image alt or caption. {%- endcomment -%}
<section class="lookbook page-width">
  <div class="lookbook__header">
    {% if section.settings.show_heading %}
      <h1 class="lookbook__title">{{ section.settings.heading | default: 'As Seen On' }}</h1>
    {% endif %}
    {% if section.settings.subheading != blank %}
      <p class="lookbook__subheading">{{ section.settings.subheading }}</p>
    {% endif %}
  </div>
  <div class="lookbook__grid" style="--cols: {{ section.settings.columns }};">
    {% for block in section.blocks %}
      {% case block.type %}
        {% when 'image' %}
          <div class="lookbook__item" {{ block.shopify_attributes }}>
            {% if block.settings.link != blank %}
              <a href="{{ block.settings.link }}" class="lookbook__link">
            {% endif %}
            <div class="lookbook__image-wrap">
              {% if block.settings.image != blank %}
                <img
                  src="{{ block.settings.image | image_url: width: 600 }}"
                  alt="{{ block.settings.image.alt | default: block.settings.caption | default: 'Lookbook image' }}"
                  class="lookbook__image"
                  loading="lazy"
                  width="300"
                  height="300"
                >
                {% if block.settings.inset_image != blank %}
                  <div class="lookbook__inset">
                    <img
                      src="{{ block.settings.inset_image | image_url: width: 200 }}"
                      alt="{{ block.settings.inset_image.alt | default: block.settings.caption | default: 'Lookbook detail' }}"
                      class="lookbook__inset-image"
                      loading="lazy"
                      width="100"
                      height="100"
                    >
                  </div>
                {% endif %}
              {% else %}
                <div class="lookbook__placeholder">{{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}</div>
              {% endif %}
            </div>
            {% if block.settings.caption != blank %}
              <p class="lookbook__caption">{{ block.settings.caption }}</p>
            {% endif %}
            {% if block.settings.link != blank %}
              </a>
            {% endif %}
          </div>
      {% endcase %}
    {% endfor %}
  </div>
</section>

<style>
.lookbook { padding: 48px 0 80px; }
.lookbook__header { text-align: center; margin-bottom: 40px; }
.lookbook__title { font-size: 12px; letter-spacing: 0.25em; font-weight: var(--font-weight-medium); margin: 0; }
.lookbook__subheading { font-size: 11px; letter-spacing: 0.15em; color: #555; margin: 8px 0 0; }
.lookbook__grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; max-width: 560px; margin: 0 auto; }
@media (min-width: 640px) { .lookbook__grid { gap: 20px; max-width: 680px; } }
@media (min-width: 1024px) { .lookbook__grid { grid-template-columns: repeat(var(--cols, 2), 1fr); gap: 24px; max-width: none; } }
.lookbook__item { }
.lookbook__link { display: block; text-decoration: none; color: inherit; }
.lookbook__image-wrap {
  position: relative;
  aspect-ratio: 1 / 1;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  background: transparent;
}
.lookbook__image {
  width: 100%;
  height: 100%;
  object-fit: contain;
  transition: transform 0.3s ease;
}
.lookbook__link:hover .lookbook__image { transform: scale(1.02); }
.lookbook__inset {
  position: absolute;
  bottom: 12px;
  right: 12px;
  width: 32%;
  max-width: 120px;
  aspect-ratio: 1 / 1;
  border: 3px solid #fff;
  box-shadow: 0 2px 12px rgba(0,0,0,0.15);
  overflow: hidden;
}
.lookbook__inset-image {
  width: 100%;
  height: 100%;
  object-fit: contain;
}
.lookbook__placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f5f5f3;
}
.lookbook__caption { font-size: 10px; letter-spacing: 0.2em; margin: 8px 0 0; text-align: center; }
</style>

{% schema %}
{
  "name": "Lookbook",
  "tag": "section",
  "class": "section-lookbook",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_heading",
      "label": "Show heading",
      "default": true
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "As Seen On"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Columns (desktop)",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 2
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Model / Look image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "image_picker",
          "id": "inset_image",
          "label": "Inset image (picture-in-picture)"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Caption"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Lookbook",
      "blocks": [
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" }
      ]
    }
  ]
}
{% endschema %}
