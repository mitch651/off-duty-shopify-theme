{% if section.settings.collection != blank %}
{% assign collection = section.settings.collection %}
<section class="featured-collection">
  <div class="page-width">
    <h2 class="featured-collection__heading">{{ section.settings.heading | default: 'Popular' }}</h2>
    <div class="featured-collection__grid" style="--cols: {{ section.settings.columns }};">
      {% for product in collection.products limit: section.settings.products_to_show %}
        {% render 'product-card', product: product %}
      {% endfor %}
    </div>
    {% if section.settings.show_view_all %}
      <div class="featured-collection__cta">
        <a href="{{ collection.url }}" class="featured-collection__link">{{ section.settings.view_all_text }}</a>
      </div>
    {% endif %}
  </div>
</section>
{% endif %}

{% schema %}
{
  "name": "Featured collection",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Popular"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 12,
      "step": 1,
      "label": "Products to show",
      "default": 4
    },
    {
      "type": "range",
      "id": "columns",
      "min": 2,
      "max": 4,
      "step": 1,
      "label": "Columns (desktop)",
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Show view all link",
      "default": true
    },
    {
      "type": "text",
      "id": "view_all_text",
      "label": "View all text",
      "default": "View All"
    }
  ]
}
{% endschema %}
