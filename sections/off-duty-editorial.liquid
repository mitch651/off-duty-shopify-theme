{% if section.settings.image != blank %}
<section class="editorial">
  <div class="page-width">
    <a href="{{ section.settings.link | default: '#' }}" class="editorial__link">
      <div class="editorial__image-wrap">
        <img
          src="{{ section.settings.image | image_url: width: 1184 }}"
          alt="{{ section.settings.image.alt | default: section.settings.subheading }}"
          class="editorial__image"
          loading="lazy"
        >
      </div>
      <div class="editorial__caption">
        <p class="editorial__label">{{ section.settings.subheading }}</p>
        <p class="editorial__title">{{ section.settings.heading }}</p>
      </div>
    </a>
  </div>
</section>
{% endif %}

{% schema %}
{
  "name": "Editorial block",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Editorial"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Spring 2026 Lookbook"
    }
  ]
}
{% endschema %}
