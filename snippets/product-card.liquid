<a href="{{ product.url }}" class="product-card{% unless product.available %} is-sold-out{% endunless %}">
  <div class="product-card__image-wrap{% if product.images.size > 1 %} product-card__image-wrap--swipeable{% endif %}">
    {% if product.images.size > 1 %}
      <div class="product-card__carousel">
        {% for image in product.images limit: 5 %}
          <div class="product-card__carousel-item">
            <img
              src="{{ image | image_url: width: 900 }}"
              alt="{{ image.alt | default: product.title }}"
              class="product-card__image"
              loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
              width="900"
              height="900"
            >
          </div>
        {% endfor %}
      </div>
    {% elsif product.featured_image %}
      <img
        src="{{ product.featured_image | image_url: width: 900 }}"
        alt="{{ product.featured_image.alt | default: product.title }}"
        class="product-card__image"
        loading="lazy"
        width="900"
        height="900"
      >
    {% else %}
      {{ 'product-1' | placeholder_svg_tag: 'product-card__image' }}
    {% endif %}
    {% unless product.available %}
      <span class="product-card__badge product-card__badge--sold-out">{{ 'products.sold_out' | t | default: 'Sold Out' }}</span>
    {% endunless %}
    <span class="product-card__hover">{{ 'products.view_product' | t | default: 'View Product' }}</span>
  </div>
  <div class="product-card__content">
    <p class="product-card__title">{{ product.title }}</p>
    <p class="product-card__price">{{ product.price | money }}</p>
  </div>
</a>
